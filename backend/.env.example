PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# CORS origin — the deployed frontend (Vercel) URL.
FRONTEND_URL=https://your-frontend.vercel.app

# APP_URL MUST be the FRONTEND origin (Vercel), not the backend (Render).
# It is used to build email links: `${APP_URL}/reset-password?token=...` and
# `${APP_URL}/verify-email?token=...`. A wrong value = dead links in emails.
APP_URL=https://your-frontend.vercel.app

GROQ_API_KEY=your_groq_api_key

# Brevo (transactional email). EMAIL_FROM must be a VERIFIED sender/domain in
# your Brevo account or OTP + password-reset emails silently fail in production.
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=noreply@yourdomain.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
